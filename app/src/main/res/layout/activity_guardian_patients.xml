<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_gradient">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/guardian_patients_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:navigationIconTint="#10172D"
        app:title="Linked patients"
        app:titleTextColor="#10172D" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:text="Linked patients"
        android:textStyle="bold"
        android:textSize="24sp"
        android:textColor="#10172D"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btn_add_patient"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Add patient by ID"
        android:background="@drawable/rounded_button_blue"
        android:textColor="@android:color/white"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No patients linked yet. Add one by ID."
        android:textColor="#6B7897"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/patients_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
